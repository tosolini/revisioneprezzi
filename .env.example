# Copy to .env and adjust. .env is gitignored.
# These power docker-compose.yml and the backend Settings.

# --- Database credentials ---
# Change the password even for local use; the default is a placeholder.
POSTGRES_USER=revuser
POSTGRES_PASSWORD=changeme-local-only
POSTGRES_DB=revision_db

# --- Backend ---
# Keep DEBUG=false unless actively debugging; true can leak internals in responses.
DEBUG=false
# DATABASE_URL is derived from the POSTGRES_* vars in docker-compose.
# Override here only if running the backend outside compose.
# DATABASE_URL=postgresql://revuser:changeme-local-only@localhost:5433/revision_db
